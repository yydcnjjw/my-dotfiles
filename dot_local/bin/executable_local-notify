#!/bin/sh

set -eu

app_name=
urgency=
icon=
expire_time=

usage() {
  printf '%s\n' 'Usage: local-notify [-a app_name] [-u urgency] [-i icon] [-t expire_time] summary [body]' >&2
  exit 1
}

require_value() {
  [ "$#" -ge 2 ] || usage
  case "$2" in
    -*) usage ;;
  esac
}

is_wsl() {
  [ -r /proc/version ] && grep -qi microsoft /proc/version
}

powershell_path() {
  if [ -n "${LOCAL_NOTIFY_PWSH:-}" ]; then
    printf '%s\n' "$LOCAL_NOTIFY_PWSH"
  else
    printf '%s\n' '/mnt/c/Users/yydcnjjw/AppData/Local/Microsoft/WindowsApps/Microsoft.PowerShell_8wekyb3d8bbwe/pwsh.exe'
  fi
}

escape_ps_single_quoted() {
  printf '%s' "$1" | sed "s/'/''/g"
}

send_wsl_notification() {
  ps_path=$(powershell_path)

  [ -x "$ps_path" ] || [ -f "$ps_path" ] || return 1

  title=$summary

  escaped_title=$(escape_ps_single_quoted "$title")
  escaped_body=$(escape_ps_single_quoted "$body")

  if "$ps_path" -NoProfile -NonInteractive -Command "Get-Module -ListAvailable BurntToast" >/dev/null 2>&1; then
    if [ -n "$body" ]; then
      "$ps_path" -NoProfile -NonInteractive -Command "New-BurntToastNotification -Text '$escaped_title', '$escaped_body'" && return 0
    else
      "$ps_path" -NoProfile -NonInteractive -Command "New-BurntToastNotification -Text '$escaped_title'" && return 0
    fi
  fi

  "$ps_path" -NoProfile -NonInteractive -Command "
    [reflection.assembly]::loadwithpartialname('System.Windows.Forms') | Out-Null;
    [reflection.assembly]::loadwithpartialname('System.Drawing') | Out-Null;
    \$notification = New-Object System.Windows.Forms.NotifyIcon;
    \$notification.Icon = [System.Drawing.SystemIcons]::Information;
    \$notification.BalloonTipIcon = 'Info';
    \$notification.BalloonTipTitle = '$escaped_title';
    \$notification.BalloonTipText = '$escaped_body';
    \$notification.Visible = \$true;
    \$notification.ShowBalloonTip(5000);
    Start-Sleep -Seconds 5;
    \$notification.Dispose();
  " >/dev/null 2>&1
}

run_voice_notification() {
  [ "${NOTIFY_VOICE_ENABLED:-1}" != "0" ] || return 0
  command -v notify-voice >/dev/null 2>&1 || return 0
  command -v timeout >/dev/null 2>&1 || return 0

  voice_timeout=${NOTIFY_VOICE_TIMEOUT:-20}
  case "$voice_timeout" in
    ""|*[!0-9]* ) voice_timeout=20 ;;
  esac

  timeout "$voice_timeout" notify-voice "$summary" "$body" >/dev/null 2>&1 || true
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -a|--app-name)
      require_value "$@"
      app_name=$2
      shift 2
      ;;
    -u|--urgency)
      require_value "$@"
      urgency=$2
      shift 2
      ;;
    -i|--icon)
      require_value "$@"
      icon=$2
      shift 2
      ;;
    -t|--expire-time)
      require_value "$@"
      expire_time=$2
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      usage
      ;;
    *)
      break
      ;;
  esac
done

[ "$#" -ge 1 ] && [ "$#" -le 2 ] || usage

case "$urgency" in
  ""|low|normal|critical) ;;
  *) usage ;;
esac

case "$expire_time" in
  ""|*[!0-9]*)
    [ -z "$expire_time" ] || usage
    ;;
esac

summary=$1
body=${2-}

if is_wsl; then
  send_wsl_notification
  exit $?
fi

run_voice_notification

uid=$(id -u)
export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$uid}
export DBUS_SESSION_BUS_ADDRESS=${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}

command -v notify-send >/dev/null 2>&1 || {
  printf '%s\n' 'local-notify: notify-send not found' >&2
  exit 1
}

set -- notify-send

[ -n "$app_name" ] && set -- "$@" -a "$app_name"
[ -n "$urgency" ] && set -- "$@" -u "$urgency"
[ -n "$icon" ] && set -- "$@" -i "$icon"
[ -n "$expire_time" ] && set -- "$@" -t "$expire_time"

set -- "$@" "$summary"
[ -n "$body" ] && set -- "$@" "$body"

exec "$@"
