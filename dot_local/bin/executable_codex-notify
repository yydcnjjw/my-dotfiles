#!/bin/sh

set -u

raw_summary=${1:-Codex}

summary=Codex
message=

parse_codex_payload() {
  command -v jq >/dev/null 2>&1 || return 1
  printf '%s' "$1" | jq -r '
    def clean:
      tostring
      | gsub("\\s+"; " ")
      | gsub("^\\s+|\\s+$"; "");

    if type != "object" then error("payload must be object") else . end
    | . as $payload
    | ($payload.type // "Codex" | clean) as $summary
    | (
        if ($payload["input-messages"] | type) == "array" then
          $payload["input-messages"]
          | map(select(type == "string") | clean | select(. != ""))
          | last // ""
        else
          ""
        end
      ) as $input_messages
    | ($payload["last-assistant-message"] // "" | clean) as $last_assistant_message
    | [
        $input_messages,
        $last_assistant_message
      ]
    | map(select(. != ""))
    | [$summary, join("\n\n")]
    | .[]
  ' 2>/dev/null
}

if parsed=$(parse_codex_payload "$raw_summary"); then
  summary=$(printf '%s\n' "$parsed" | sed -n '1p')
  message=$(printf '%s\n' "$parsed" | sed '1d')
fi

exec agent-notify -a Codex "$summary" "$message"
