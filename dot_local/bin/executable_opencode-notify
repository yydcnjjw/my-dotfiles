#!/bin/sh

set -u

event=${1:-Notification}
message=${2:-}
summary="OpenCode - $event"

send_notification() {
  if [ -n "${REMOTE_NOTIFY_HOST:-}" ] && command -v remote-notify >/dev/null 2>&1; then
    remote-notify -a OpenCode "$summary" "$message" && return 0
  fi

  if command -v local-notify >/dev/null 2>&1; then
    local-notify -a OpenCode "$summary" "$message" && return 0
  fi

  printf 'Notification: %s: %s\n' "$summary" "$message"
  return 0
}

send_notification
