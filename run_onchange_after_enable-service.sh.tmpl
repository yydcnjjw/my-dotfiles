#!/bin/bash

# tmux.service hash: {{ include "dot_config/systemd/user/tmux.service" | sha256sum }}
# sway.service hash: {{ include "dot_config/systemd/user/sway.service" | sha256sum }}
# emacs override hash: {{ include "dot_config/systemd/user/emacs.service.d/override.conf" | sha256sum }}

if command -v systemctl >/dev/null 2>&1; then
    systemctl --user daemon-reload
    systemctl --user enable --now sway.service
    systemctl --user enable --now tmux.service
    systemctl --user enable --now emacs.service
fi
