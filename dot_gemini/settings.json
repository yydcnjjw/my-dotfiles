{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/notify.sh",
            "name": "Desktop Notification",
            "description": "通过 remote-notify 或 local-notify 发送 Gemini 通知"
          }
        ]
      }
    ]
  },
  "hooksConfig": {
    "enabled": true
  },
  "general": {
    "enableNotifications": true
  }
}
