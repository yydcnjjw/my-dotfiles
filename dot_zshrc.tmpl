# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load
ZSH_THEME="ys"

# Which plugins would you like to load?
plugins=(
  git
  extract
  archlinux
  docker
  eza
  zoxide
  fzf
  fzf-tab
  zsh-autosuggestions
  {{- if not .is_wsl }}
  auto-notify
  {{- end }}
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# User configuration
if command -v bat >/dev/null 2>&1; then
  alias cat='bat'
elif command -v batcat >/dev/null 2>&1; then
  alias cat='batcat'
fi

if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons=auto'
  alias ll='eza -l --icons=auto'
  alias la='eza -la --icons=auto'
fi

if command -v remote-notify >/dev/null 2>&1; then
  _local_notify_send="$(whence -p notify-send 2>/dev/null || true)"

  notify-send() {
    if [ -n "${REMOTE_NOTIFY_HOST:-}" ]; then
      remote-notify "$@"
    elif [ -n "$_local_notify_send" ]; then
      "$_local_notify_send" "$@"
    else
      return 127
    fi
  }
fi

# Auto-start and attach to tmux
if [ -z "$TMUX" ] && [ -n "$PS1" ]; then
    tmux new-session -A -s "$USER"
fi
