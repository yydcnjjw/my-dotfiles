{
  "layer": "top",
  "position": "top",
  "height": 24,
  "spacing": 0,
  "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
  "modules-center": ["sway/window"],
  "modules-right": ["pulseaudio", "network", "cpu", "memory", "tray", "clock"],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "cpu": {
    "format": "ΎΜδ {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "ΎΔΚ {}%"
  },
  "network": {
    "format-wifi": "ΎΘτ {essid} ({signalStrength}%)",
    "format-ethernet": "≤░ΙΑ {ipaddr}/{cidr}",
    "tooltip-format": "≤░ΙΑ {ifname} via {gwaddr}",
    "format-linked": "≤░ΙΑ {ifname} (No IP)",
    "format-disconnected": "≤░ΙΓ Disconnected έγι",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "pulseaudio": {
	"format": "{volume}% {icon}",
	"format-bluetooth": "{volume}% ΎΑξ ΎΛΦ",
	"format-muted": "ΎΑο",
	"format-icons": {
	  "headphone": "ΎΑξ",
	  "hands-free": "ΎΨΡ",
	  "headset": "ΎΨΡ",
	  "phone": "ΎΓΧ",
	  "phone-muted": "Ό┤Ω",
	  "portable": "ΎΓΧ",
	  "car": "ΎΗ╣",
	  "default": ["ΎΑπ", "ΎΑρ"]
	},
	"scroll-step": 1,
	"on-click": "pavucontrol"
  }
}
