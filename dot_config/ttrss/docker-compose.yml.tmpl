services:
  db:
    image: postgres:17-alpine
    restart: unless-stopped
    env_file:
      - .env
    environment:
      - POSTGRES_USER=${TTRSS_DB_USER}
      - POSTGRES_PASSWORD=${TTRSS_DB_PASS}
      - POSTGRES_DB=${TTRSS_DB_NAME}
    volumes:
      - db:/var/lib/postgresql/data

  app:
    image: supahgreg/tt-rss:latest
    restart: unless-stopped
    env_file:
      - .env
    {{- if .use_proxy_for_ttrss }}
    environment:
      - HTTP_PROXY=http://{{ if or (eq .proxy_ip "127.0.0.1") (eq .proxy_ip "localhost") }}host.docker.internal{{ else }}{{ .proxy_ip }}{{ end }}:{{ .http_port }}
      - HTTPS_PROXY=http://{{ if or (eq .proxy_ip "127.0.0.1") (eq .proxy_ip "localhost") }}host.docker.internal{{ else }}{{ .proxy_ip }}{{ end }}:{{ .http_port }}
    {{- end }}
    volumes:
      - app:/var/www/html
      - ./config.d:/opt/tt-rss/config.d:ro
    depends_on:
      - db
    extra_hosts:
      - "host.docker.internal:host-gateway"

  updater:
    image: supahgreg/tt-rss:latest
    restart: unless-stopped
    env_file:
      - .env
    {{- if .use_proxy_for_ttrss }}
    environment:
      - HTTP_PROXY=http://{{ if or (eq .proxy_ip "127.0.0.1") (eq .proxy_ip "localhost") }}host.docker.internal{{ else }}{{ .proxy_ip }}{{ end }}:{{ .http_port }}
      - HTTPS_PROXY=http://{{ if or (eq .proxy_ip "127.0.0.1") (eq .proxy_ip "localhost") }}host.docker.internal{{ else }}{{ .proxy_ip }}{{ end }}:{{ .http_port }}
    {{- end }}
    volumes:
      - app:/var/www/html
      - ./config.d:/opt/tt-rss/config.d:ro
    depends_on:
      - app
    extra_hosts:
      - "host.docker.internal:host-gateway"
    command: /opt/tt-rss/updater.sh

  web-nginx:
    image: supahgreg/tt-rss-web-nginx:latest
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - ${HTTP_PORT}:80
    volumes:
      - app:/var/www/html:ro
    depends_on:
      - app

volumes:
  db:
  app:
  backups:
