# tt-rss .env template

# Database credentials
TTRSS_DB_USER=ttrss
TTRSS_DB_NAME=ttrss
TTRSS_DB_PASS={{ .ttrss_db_pass }}

# External access URL (MANDATORY)
TTRSS_SELF_URL_PATH={{ .ttrss_url }}

# Port to expose on the host
HTTP_PORT=8280

# Other settings
ADMIN_USER_PASS=password

# Proxy configuration for feed fetching
{{- if .use_proxy_for_ttrss }}
# TTRSS constants for proxy:
# _PROXY_ADDRESS (host), _PROXY_PORT (port), _PROXY_TYPE (CURLPROXY_HTTP=0, CURLPROXY_SOCKS5=5)
{{- if or (eq .proxy_ip "127.0.0.1") (eq .proxy_ip "localhost") }}
TTRSS_PROXY_ADDRESS=host.docker.internal
{{- else }}
TTRSS_PROXY_ADDRESS={{ .proxy_ip }}
{{- end }}
TTRSS_PROXY_PORT={{ .http_port }}
TTRSS_PROXY_TYPE=0
{{- end }}
