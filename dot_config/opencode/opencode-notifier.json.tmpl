{
  "notification": false,
  "sound": false,
  "showSessionTitle": true,
  "linux": {
    "grouping": true
  },
  "command": {
    "enabled": true,
    "path": "{{ .chezmoi.homeDir }}/.local/bin/opencode-notify",
    "args": [
      "{event}",
      "{message}"
    ]
  },
  "events": {
    "permission": { "sound": true, "notification": true, "command": true, "bell": false },
    "complete": { "sound": true, "notification": true, "command": true, "bell": false },
    "subagent_complete": { "sound": false, "notification": false, "command": false, "bell": false },
    "error": { "sound": true, "notification": true, "command": true, "bell": false },
    "question": { "sound": true, "notification": true, "command": true, "bell": false },
    "user_cancelled": { "sound": false, "notification": false, "command": false, "bell": false },
    "plan_exit": { "sound": true, "notification": true, "command": true, "bell": false },
    "session_started": { "sound": true, "notification": false, "command": false, "bell": false },
    "user_message": { "sound": true, "notification": false, "command": false, "bell": false },
    "client_connected": { "sound": true, "notification": false, "command": false, "bell": false }
  }
}
